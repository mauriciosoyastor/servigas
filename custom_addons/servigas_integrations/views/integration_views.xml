<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_servigas_integration_kanban" model="ir.ui.view">
        <field name="name">servigas.integration.kanban</field>
        <field name="model">servigas.integration</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_dashboard sg-integrations-kanban" create="false" delete="false">
                <field name="name"/>
                <field name="integration_type"/>
                <field name="mode"/>
                <field name="status"/>
                <field name="description"/>
                <field name="process_notes"/>
                <field name="resource_path"/>
                <field name="color"/>
                <templates>
                    <t t-name="card">
                        <div class="sg-integration-card">
                        <div class="sg-integration-card__header">
                            <strong class="sg-integration-card__title">
                                <field name="name"/>
                            </strong>
                            <span t-attf-class="badge rounded-pill sg-integration-card__status sg-integration-card__status--#{record.status.raw_value}">
                                <field name="status"/>
                            </span>
                        </div>
                        <div class="sg-integration-card__meta">
                            <span class="badge text-bg-secondary">
                                <field name="mode"/>
                            </span>
                            <span class="badge text-bg-light border">
                                <field name="integration_type"/>
                            </span>
                        </div>
                        <p class="sg-integration-card__description text-muted mb-2">
                            <field name="description"/>
                        </p>
                        <div class="sg-integration-card__notes" t-if="record.process_notes.raw_value">
                            <span class="fw-semibold">Proceso:</span>
                            <field name="process_notes"/>
                        </div>
                        <div class="sg-integration-card__resource text-muted small" t-if="record.resource_path.raw_value">
                            <i class="fa fa-folder-open-o me-1" title="Recurso"/>
                            <field name="resource_path"/>
                        </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_servigas_integration_list" model="ir.ui.view">
        <field name="name">servigas.integration.list</field>
        <field name="model">servigas.integration</field>
        <field name="arch" type="xml">
            <list create="false" delete="false">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="integration_type"/>
                <field name="mode"/>
                <field name="status"/>
                <field name="resource_path"/>
            </list>
        </field>
    </record>

    <record id="view_servigas_integration_form" model="ir.ui.view">
        <field name="name">servigas.integration.form</field>
        <field name="model">servigas.integration</field>
        <field name="arch" type="xml">
            <form create="false" delete="false">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="integration_type" readonly="1"/>
                            <field name="mode" readonly="1"/>
                            <field name="status" readonly="1"/>
                        </group>
                        <group>
                            <field name="resource_path" readonly="1"/>
                            <field name="sequence" readonly="1"/>
                        </group>
                    </group>
                    <group string="Descripción">
                        <field name="description" nolabel="1" readonly="1"/>
                    </group>
                    <group string="Proceso operativo">
                        <field name="process_notes" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_servigas_integration_search" model="ir.ui.view">
        <field name="name">servigas.integration.search</field>
        <field name="model">servigas.integration</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="integration_type"/>
                <field name="status"/>
                <filter string="Activas" name="active" domain="[('status', '=', 'active')]"/>
                <filter string="Manuales" name="manual" domain="[('mode', '=', 'manual')]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Tipo" name="group_type" context="{'group_by': 'integration_type'}"/>
                    <filter string="Estado" name="group_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_servigas_integrations_dashboard" model="ir.actions.act_window">
        <field name="name">Integraciones</field>
        <field name="res_model">servigas.integration</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_servigas_integration_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Panel de integraciones Servigas
            </p>
            <p>
                Aquí centralizamos los puentes con Factura Web y los portales de proveedores.
            </p>
        </field>
    </record>
</odoo>
