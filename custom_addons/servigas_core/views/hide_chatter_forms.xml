<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ADR 0015: sin chatter + ancla sg-form-no-chatter (sheet ancho completo vía SCSS). -->

    <!-- Inventario P1 -->
    <record id="sg_product_category_form_hide_chatter" model="ir.ui.view">
        <field name="name">product.category.form.sg.hide.chatter</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes">
                <attribute name="class" add="sg-form-no-chatter" separator=" "/>
            </xpath>
            <xpath expr="//chatter" position="replace"/>
        </field>
    </record>

