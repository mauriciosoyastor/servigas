<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form producto: sin chatter + ancla CSS para mini KPI (stat buttons). -->
    <record id="sg_product_template_form_hide_chatter" model="ir.ui.view">
        <field name="name">product.template.form.sg.hide.chatter</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes">
                <attribute name="class" add="sg-form-no-chatter sg-product-form" separator=" "/>
            </xpath>
            <xpath expr="//chatter" position="replace"/>
        </field>
    </record>
</odoo>
