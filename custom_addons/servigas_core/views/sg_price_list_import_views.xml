<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sg_price_list_import_wizard_form" model="ir.ui.view">
        <field name="name">sg.price.list.import.wizard.form</field>
        <field name="model">sg.price.list.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Cargar lista de precios">
                <field name="state" invisible="1"/>
                <group invisible="state != 'upload'">
                    <group>
                        <field name="file_data" filename="filename"/>
                        <field name="filename"/>
                    </group>
                    <group>
                        <div class="text-muted">
                            Formatos: CSV o Excel (.xlsx). PDF e imágenes no están soportados:
                            convertí a Excel/CSV primero.
                        </div>
                    </group>
                </group>
                <group invisible="state != 'mapping'" string="Mapear columnas">
                    <field name="headers_text" readonly="1"/>
                    <group>
                        <field name="map_barcode"/>
                        <field name="map_default_code"/>
                        <field name="map_name"/>
                        <field name="map_list_price"/>
                        <field name="map_standard_price"/>
                    </group>
                    <div class="text-muted">
                        Escribí el nombre exacto de la columna del archivo (se sugiere solo).
                        El nombre es obligatorio; al menos un precio (venta o costo) también.
                    </div>
                </group>
                <group invisible="state != 'preview'" string="Preview">
                    <field name="line_ids" nolabel="1">
                        <list editable="bottom" create="0" delete="0">
                            <field name="selected"/>
                            <field name="line_number"/>
                            <field name="status"/>
                            <field name="barcode"/>
                            <field name="default_code"/>
                            <field name="name"/>
                            <field name="list_price"/>
                            <field name="standard_price"/>
                            <field name="product_id"
                                     readonly="status != 'review'"
                                     options="{'no_create': True}"/>
                            <field name="reason"/>
                        </list>
                    </field>
                </group>
                <group invisible="state != 'done'" string="Resultado">
                    <field name="created_count"/>
                    <field name="updated_count"/>
                    <field name="skipped_count"/>
                    <field name="message" nolabel="1"/>
                </group>
                <footer>
                    <button name="action_download_template"
                            type="object"
                            string="Descargar plantilla"
                            class="btn-secondary"
                            invisible="state != 'upload'"/>
                    <button name="action_parse_file"
                            type="object"
                            string="Continuar"
                            class="btn-primary"
                            invisible="state != 'upload'"/>
                    <button name="action_back_to_upload"
                            type="object"
                            string="Atrás"
                            class="btn-secondary"
                            invisible="state != 'mapping'"/>
                    <button name="action_build_preview"
                            type="object"
                            string="Ver preview"
                            class="btn-primary"
                            invisible="state != 'mapping'"/>
                    <button name="action_back_to_mapping"
                            type="object"
                            string="Atrás"
                            class="btn-secondary"
                            invisible="state != 'preview'"/>
                    <button name="action_apply"
                            type="object"
                            string="Confirmar e importar"
                            class="btn-primary"
                            invisible="state != 'preview'"/>
                    <button string="Cerrar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sg_price_list_import" model="ir.actions.act_window">
        <field name="name">Cargar lista de precios</field>
        <field name="res_model">sg.price.list.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_sg_price_list_import_wizard_form"/>
    </record>

    <record id="view_sg_price_list_import_log_list" model="ir.ui.view">
        <field name="name">sg.price.list.import.log.list</field>
        <field name="model">sg.price.list.import.log</field>
        <field name="arch" type="xml">
            <list string="Importaciones de lista de precios" create="0" edit="0">
                <field name="create_date"/>
                <field name="name"/>
                <field name="filename"/>
                <field name="user_id"/>
                <field name="created_count"/>
                <field name="updated_count"/>
                <field name="skipped_count"/>
            </list>
        </field>
    </record>
</odoo>
