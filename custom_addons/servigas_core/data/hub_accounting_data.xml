        <record id="hub_card_acc_recv_invoices" model="sg.hub.card">
            <field name="app">accounting</field>
            <field name="section">receivables</field>
            <field name="sequence">10</field>
            <field name="label">Facturas de cliente</field>
            <field name="icon">fa-file-text-o</field>
            <field name="action_id" ref="account.action_move_out_invoice"/>
