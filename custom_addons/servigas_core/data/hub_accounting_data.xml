            <field name="metric_domain">[('move_type', '=', 'out_invoice'), ('state', '=', 'draft')]</field>
            <field name="metric_aggregate">count</field>
        </record>
        <record id="hub_card_acc_recv_payments" model="sg.hub.card">
            <field name="app">accounting</field>
            <field name="section">receivables</field>
            <field name="sequence">40</field>
