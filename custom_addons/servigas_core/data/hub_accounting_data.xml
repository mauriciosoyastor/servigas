<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Secciones rail — Facturación -->
        <record id="hub_section_accounting_summary" model="sg.hub.section">
            <field name="app">accounting</field>
            <field name="code">summary</field>
            <field name="name">Resumen</field>
            <field name="icon">fa-th-large</field>
            <field name="sequence">1</field>
        </record>
        <record id="hub_section_accounting_receivables" model="sg.hub.section">
            <field name="app">accounting</field>
            <field name="code">receivables</field>
            <field name="name">Clientes</field>
            <field name="icon">fa-user</field>
            <field name="sequence">2</field>
        </record>
        <record id="hub_section_accounting_payables" model="sg.hub.section">
            <field name="app">accounting</field>
            <field name="code">payables</field>
            <field name="name">Proveedores</field>
            <field name="icon">fa-truck</field>
            <field name="sequence">3</field>
        </record>
        <record id="hub_section_accounting_reporting" model="sg.hub.section">
            <field name="app">accounting</field>
            <field name="code">reporting</field>
            <field name="name">Informes</field>
            <field name="icon">fa-bar-chart</field>
            <field name="sequence">4</field>
        </record>
        <record id="hub_section_accounting_config" model="sg.hub.section">
            <field name="app">accounting</field>
            <field name="code">config</field>
            <field name="name">Configuración</field>
            <field name="icon">fa-cog</field>
            <field name="sequence">5</field>
        </record>

        <!-- Cards — Resumen -->
        <record id="hub_card_acc_summary_receivable_unpaid" model="sg.hub.card">
            <field name="app">accounting</field>
            <field name="section">summary</field>
            <field name="show_in_summary" eval="True"/>
            <field name="sequence">10</field>
            <field name="label">Por cobrar</field>
            <field name="hint">Facturas de cliente pendientes</field>
            <field name="icon">fa-money</field>
            <field name="variant">warning</field>
            <field name="enter_label">Ver facturas →</field>
            <field name="action_id" ref="account.action_move_out_invoice"/>
            <field name="domain">[('move_type', '=', 'out_invoice'), ('state', '=', 'posted'), ('payment_state', 'in', ('not_paid', 'partial', 'in_payment'))]</field>
            <field name="metric_model">account.move</field>
            <field name="metric_domain">[('move_type', '=', 'out_invoice'), ('state', '=', 'posted'), ('payment_state', 'in', ('not_paid', 'partial', 'in_payment'))]</field>
            <field name="metric_aggregate">count</field>
        </record>
        <record id="hub_card_acc_summary_payable_unpaid" model="sg.hub.card">
            <field name="app">accounting</field>
            <field name="section">summary</field>
            <field name="show_in_summary" eval="True"/>
            <field name="sequence">20</field>
            <field name="label">Por pagar</field>
            <field name="hint">Facturas de proveedor pendientes</field>
            <field name="icon">fa-credit-card</field>
            <field name="variant">warning</field>
            <field name="enter_label">Ver facturas →</field>
            <field name="action_id" ref="account.action_move_in_invoice"/>
            <field name="domain">[('move_type', '=', 'in_invoice'), ('state', '=', 'posted'), ('payment_state', 'in', ('not_paid', 'partial', 'in_payment'))]</field>
            <field name="metric_model">account.move</field>
            <field name="metric_domain">[('move_type', '=', 'in_invoice'), ('state', '=', 'posted'), ('payment_state', 'in', ('not_paid', 'partial', 'in_payment'))]</field>
            <field name="metric_aggregate">count</field>
        </record>
        <record id="hub_card_acc_summary_drafts" model="sg.hub.card">
            <field name="app">accounting</field>
            <field name="section">summary</field>
            <field name="show_in_summary" eval="True"/>
            <field name="sequence">30</field>
            <field name="label">Borradores</field>
            <field name="hint">Facturas sin publicar</field>
            <field name="icon">fa-pencil</field>
            <field name="enter_label">Revisar →</field>
            <field name="action_id" ref="account.action_move_out_invoice"/>
            <field name="domain">[('state', '=', 'draft'), ('move_type', 'in', ('out_invoice', 'in_invoice'))]</field>
            <field name="metric_model">account.move</field>
            <field name="metric_domain">[('state', '=', 'draft'), ('move_type', 'in', ('out_invoice', 'in_invoice'))]</field>
            <field name="metric_aggregate">count</field>
        </record>
        <record id="hub_card_acc_summary_payments" model="sg.hub.card">
            <field name="app">accounting</field>
            <field name="section">summary</field>
            <field name="show_in_summary" eval="True"/>
            <field name="sequence">40</field>
            <field name="label">Pagos registrados</field>
            <field name="hint">Pagos publicados</field>
            <field name="icon">fa-bank</field>
            <field name="enter_label">Ver pagos →</field>
            <field name="action_id" ref="account.action_account_all_payments"/>
            <field name="metric_model">account.payment</field>
            <field name="metric_domain">[('state', '=', 'posted')]</field>
            <field name="metric_aggregate">count</field>
        </record>
        <record id="hub_card_acc_summary_invoiced_today" model="sg.hub.card">
            <field name="app">accounting</field>
            <field name="section">summary</field>
            <field name="show_in_summary" eval="True"/>
            <field name="sequence">50</field>
            <field name="label">Facturado hoy</field>
            <field name="hint">Total FC publicadas hoy</field>
            <field name="icon">fa-line-chart</field>
            <field name="enter_label">Ver facturas →</field>
            <field name="action_id" ref="account.action_move_out_invoice"/>
            <field name="domain">[('move_type', '=', 'out_invoice'), ('state', '=', 'posted')]</field>
            <field name="metric_model">account.move</field>
            <field name="metric_domain">[('move_type', '=', 'out_invoice'), ('state', '=', 'posted')]</field>
            <field name="metric_field">amount_total</field>
            <field name="metric_aggregate">sum</field>
            <field name="metric_date_field">date</field>
            <field name="metric_date_scope">today</field>
            <field name="metric_suffix"> $</field>
        </record>
        <record id="hub_card_acc_summary_dashboard" model="sg.hub.card">
            <field name="app">accounting</field>
            <field name="section">summary</field>
            <field name="show_in_summary" eval="True"/>
            <field name="sequence">60</field>
            <field name="label">Tablero contable</field>
            <field name="hint">Dashboard de diarios</field>
            <field name="icon">fa-dashboard</field>
            <field name="enter_label">Abrir tablero →</field>
            <field name="action_id" ref="account.open_account_journal_dashboard_kanban"/>
            <field name="metric_model">account.journal</field>
            <field name="metric_domain">[]</field>
            <field name="metric_aggregate">count</field>
        </record>

