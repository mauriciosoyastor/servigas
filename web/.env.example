# Nativo Servigas (servigas.conf): puerto 8070
# Docker mostrador (docker-compose): puerto 8069
ODOO_URL=http://127.0.0.1:8070
ODOO_DB=servigas_dev

# BFF session store: memory | file (default file outside tests)
# BFF_SESSION_STORE=file
# BFF_SESSION_TTL_SECONDS=43200
# BFF_SESSION_DIR=.data/bff-sessions

# Abort Odoo RPC / media after N ms (default 15000)
# ODOO_RPC_TIMEOUT_MS=15000
