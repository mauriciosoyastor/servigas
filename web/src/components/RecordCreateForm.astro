---
interface FieldDef {
	key: string;
	label: string;
	required?: boolean;
}

interface Props {
	listKey: string;
	apiPath: string;
	title: string;
	hint: string;
	fields: FieldDef[];
	listPath: string;
}

const { listKey, apiPath, title, hint, fields, listPath } = Astro.props;
---

<section class="sg-record-create sg-glass" data-record-create data-list-key={listKey}>
	<strong>{title}</strong>
	<p>{hint}</p>
	<form class="sg-record-create-form" data-record-create-form>
		{fields.map((field) => (
			<label>
				<span>
					{field.label}
					{field.required ? ' *' : ''}
				</span>
				<input
					class="sg-focus-ring"
					type={field.key === 'email' ? 'email' : 'text'}
					name={field.key}
					required={field.required}
					autocomplete="off"
				/>
			</label>
		))}
		<div class="sg-record-create-actions">
			<button class="sg-focus-ring" type="submit">Crear</button>
			<a class="sg-focus-ring" href={listPath}>Cancelar</a>
			<span class="sg-record-create-status" data-record-create-status hidden></span>
		</div>
	</form>
</section>

<script define:vars={{ apiPath }}>
	const root = document.querySelector('[data-record-create]');
	const form = root?.querySelector('[data-record-create-form]');
	const status = root?.querySelector('[data-record-create-status]');
	if (form instanceof HTMLFormElement && status instanceof HTMLElement) {
		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			status.hidden = false;
			status.textContent = 'Creando…';
			status.dataset.state = 'pending';

			const data = new FormData(form);
			const values = {};
			for (const [key, value] of data.entries()) {
				values[key] = String(value);
			}

			try {
				const response = await fetch(apiPath, {
					method: 'POST',
					credentials: 'same-origin',
					headers: { 'content-type': 'application/json' },
					body: JSON.stringify({ action: 'create', values }),
				});
				const payload = await response.json().catch(() => ({}));
				if (!response.ok) {
					throw new Error(payload?.error?.message || 'No se pudo crear');
				}
				status.textContent = 'Creado';
				status.dataset.state = 'ok';
				window.setTimeout(() => {
					window.location.href = payload.detailPath || '/';
				}, 350);
			} catch (error) {
				status.textContent =
					error instanceof Error ? error.message : 'No se pudo crear';
				status.dataset.state = 'error';
			}
		});
	}
</script>

<style>
	.sg-record-create {
		display: grid;
		gap: 0.65rem;
		max-width: 36rem;
		border-radius: var(--sg-radius-card);
		padding: 1.2rem;
	}
	.sg-record-create p {
		margin: 0;
		color: var(--sg-text-muted-dark);
		font-size: 0.82rem;
		line-height: 1.45;
	}
	.sg-record-create-form {
		display: grid;
		gap: 0.85rem;
		margin-top: 0.35rem;
	}
	.sg-record-create-form label {
		display: grid;
		gap: 0.35rem;
	}
	.sg-record-create-form span {
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--sg-text-muted-dark);
	}
	.sg-record-create-form input {
		border: 1px solid var(--sg-glass-border);
		border-radius: 0.75rem;
		padding: 0.65rem 0.8rem;
		color: var(--sg-text-on-dark);
		background: rgba(0, 0, 0, 0.22);
		font: inherit;
	}
	.sg-record-create-actions {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.75rem;
	}
	.sg-record-create-actions button,
	.sg-record-create-actions a {
		border: 1px solid var(--sg-glass-border);
		border-radius: var(--sg-radius-pill);
		padding: 0.6rem 1rem;
		color: var(--sg-text-on-dark);
		background: var(--sg-glass-fill);
		font-size: 0.85rem;
		font-weight: 650;
		text-decoration: none;
		cursor: pointer;
	}
	.sg-record-create-status {
		font-size: 0.8rem;
		color: var(--sg-text-muted-dark);
	}
	.sg-record-create-status[data-state='ok'] {
		color: #9be7b0;
	}
	.sg-record-create-status[data-state='error'] {
		color: #ffb4a2;
	}
</style>
