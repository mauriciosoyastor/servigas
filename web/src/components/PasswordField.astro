---
type Props = {
	name: string;
	label: string;
	autocomplete?: string;
	required?: boolean;
};

const { name, label, autocomplete = 'current-password', required = true } = Astro.props;
---

<label class="sg-password-label">
	<span>{label}</span>
	<span class="sg-password-field">
		<input
			class="sg-focus-ring"
			name={name}
			type="password"
			autocomplete={autocomplete}
			required={required}
		/>
		<button
			class="sg-password-toggle sg-focus-ring"
			type="button"
			data-password-toggle
			aria-label="Mostrar contraseña"
			aria-pressed="false"
		>
			<svg class="sg-password-icon-show" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
				<path
					fill="currentColor"
					d="M12 5c-5.05 0-9.27 3.11-11 7.5C2.73 16.89 6.95 20 12 20s9.27-3.11 11-7.5C21.27 8.11 17.05 5 12 5zm0 12.5a5 5 0 1 1 0-10 5 5 0 0 1 0 10zm0-8a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"
				></path>
			</svg>
			<svg
				class="sg-password-icon-hide"
				viewBox="0 0 24 24"
				width="20"
				height="20"
				aria-hidden="true"
				hidden
			>
				<path
					fill="currentColor"
					d="M3.28 2.22 2.22 3.28l3.01 3.01A11.9 11.9 0 0 0 1 12.5C2.73 16.89 6.95 20 12 20c1.9 0 3.68-.42 5.28-1.16l3.44 3.44 1.06-1.06L3.28 2.22zM12 18.5c-4.05 0-7.45-2.4-9-6 .66-1.68 1.8-3.14 3.24-4.2l2.12 2.12A4.98 4.98 0 0 0 7 12.5a5 5 0 0 0 6.58 4.74l1.7 1.7A9.3 9.3 0 0 1 12 18.5zm9.9-6c-.4 1.02-.98 1.96-1.7 2.78l-1.5-1.5c.4-.54.72-1.14.96-1.78-1.55-3.6-4.95-6-9-6-.58 0-1.14.06-1.68.16L7.3 4.48A11.4 11.4 0 0 1 12 4c5.05 0 9.27 3.11 11 7.5-.3.78-.7 1.5-1.15 2.16l.05-.16zM9.5 12.5c0-.4.1-.78.26-1.12l3.86 3.86A3 3 0 0 1 9.5 12.5z"
				></path>
			</svg>
		</button>
	</span>
</label>

<style>
	.sg-password-label {
		display: grid;
		gap: 0.45rem;
	}
	.sg-password-field {
		position: relative;
		display: block;
	}
	.sg-password-field input {
		width: 100%;
		box-sizing: border-box;
		border: 1px solid var(--sg-glass-border);
		border-radius: var(--sg-radius-card);
		padding: 0.75rem 2.75rem 0.75rem 0.85rem;
		color: var(--sg-text-on-dark);
		background: var(--sg-glass-fill);
		font: inherit;
	}
	.sg-password-toggle {
		position: absolute;
		top: 50%;
		right: 0.45rem;
		display: grid;
		place-items: center;
		width: 2.1rem;
		height: 2.1rem;
		transform: translateY(-50%);
		border: 0;
		border-radius: 999px;
		padding: 0;
		color: rgba(255, 255, 255, 0.62);
		background: transparent;
		cursor: pointer;
	}
	.sg-password-toggle:hover {
		color: var(--sg-text-on-dark);
		background: color-mix(in srgb, var(--sg-glass-fill) 80%, transparent);
	}
	.sg-password-toggle[aria-pressed='true'] {
		color: var(--sg-flame-yellow);
	}
	.sg-password-toggle svg {
		display: block;
	}
</style>
