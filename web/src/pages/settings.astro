---
import ShellLayout from '../layouts/ShellLayout.astro';
import { invalidateBffSession, requireOdooSession } from '../lib/bff/http.ts';

let userName = '';
let userLogin = '';
try {
	const { session } = requireOdooSession(Astro.cookies);
	userName = session.name || session.login;
	userLogin = session.login || '';
} catch {
	invalidateBffSession(Astro.cookies);
	return Astro.redirect('/login');
}

const initials = userName
	.split(/\s+/)
	.filter(Boolean)
	.slice(0, 2)
	.map((part) => part[0]?.toUpperCase() ?? '')
	.join('') || (userLogin[0]?.toUpperCase() ?? '?');
---

<ShellLayout title="Ajustes | Servigas" active="home" userName={userName}>
	<main class="sg-landing">
		<header>
			<p>Inicio</p>
			<h1>Ajustes</h1>
			<p class="sg-landing-lead">
				Gestioná tu cuenta. Otras configuraciones de empresa siguen en Integraciones.
			</p>
		</header>

		<section class="sg-landing-card sg-glass sg-settings-account" aria-labelledby="settings-account-title">
			<div class="sg-settings-account-head">
				<strong id="settings-account-title">Tu cuenta</strong>
			</div>
			<div class="sg-settings-identity">
				<span class="sg-settings-avatar" aria-hidden="true">{initials}</span>
				<div class="sg-settings-identity-text">
					<p class="sg-settings-identity-name">{userName}</p>
					<div class="sg-settings-identity-login" data-login-view>
						<span>Usuario</span>
						<code data-login-display>{userLogin}</code>
						<button
							class="sg-settings-edit-btn sg-focus-ring"
							type="button"
							data-login-edit
						>
							Editar
						</button>
					</div>
					<form class="sg-settings-login-form" data-login-form hidden>
						<label>
							<span>Usuario</span>
							<input
								class="sg-focus-ring"
								name="login"
								type="text"
								autocomplete="username"
								required
								minlength="2"
								maxlength="64"
								value={userLogin}
								data-login-input
							/>
						</label>
						<p class="sg-settings-error" data-login-error role="alert" hidden></p>
						<div class="sg-settings-login-actions">
							<button class="sg-landing-cta sg-focus-ring" type="submit">
								Guardar usuario
							</button>
							<button
								class="sg-settings-cancel sg-focus-ring"
								type="button"
								data-login-cancel
							>
								Cancelar
							</button>
						</div>
					</form>
				</div>
			</div>
		</section>

		<section class="sg-landing-card sg-glass" aria-labelledby="settings-password-title">
			<strong id="settings-password-title">Cambiar contraseña</strong>
			<p>Después de guardar vas a tener que ingresar de nuevo con la clave nueva.</p>
			<form data-change-password-form class="sg-settings-form">
				<label>
					<span>Contraseña actual</span>
					<input
						class="sg-focus-ring"
						name="currentPassword"
						type="password"
						autocomplete="current-password"
						required
					/>
				</label>
				<label>
					<span>Nueva contraseña</span>
					<input
						class="sg-focus-ring"
						name="newPassword"
						type="password"
						autocomplete="new-password"
						required
					/>
				</label>
				<label>
					<span>Confirmar nueva contraseña</span>
					<input
						class="sg-focus-ring"
						name="confirmPassword"
						type="password"
						autocomplete="new-password"
						required
					/>
				</label>
				<p class="sg-settings-error" data-change-password-error role="alert" hidden></p>
				<button class="sg-landing-cta sg-focus-ring" type="submit">
					Guardar contraseña
				</button>
			</form>
		</section>

		<section class="sg-landing-card sg-glass">
			<strong>Integraciones</strong>
			<p>Factura Web y portales de proveedores.</p>
			<a class="sg-landing-cta sg-focus-ring" href="/lists/integrations">Ver integraciones →</a>
		</section>
		<p class="sg-landing-back">
			<a href="/">← Volver al inicio</a>
		</p>
	</main>
</ShellLayout>

<script>
	const loginView = document.querySelector<HTMLElement>('[data-login-view]');
	const loginForm = document.querySelector<HTMLFormElement>('[data-login-form]');
	const loginDisplay = document.querySelector<HTMLElement>('[data-login-display]');
	const loginInput = document.querySelector<HTMLInputElement>('[data-login-input]');
	const loginEdit = document.querySelector<HTMLButtonElement>('[data-login-edit]');
	const loginCancel = document.querySelector<HTMLButtonElement>('[data-login-cancel]');
	const loginError = document.querySelector<HTMLElement>('[data-login-error]');
	const loginSubmit = loginForm?.querySelector<HTMLButtonElement>('button[type="submit"]');

	const showLoginView = () => {
		if (!loginView || !loginForm) return;
		loginForm.hidden = true;
		loginView.hidden = false;
		if (loginError) loginError.hidden = true;
	};

	const showLoginEdit = () => {
		if (!loginView || !loginForm || !loginInput || !loginDisplay) return;
		loginInput.value = loginDisplay.textContent?.trim() || '';
		loginView.hidden = true;
		loginForm.hidden = false;
		if (loginError) loginError.hidden = true;
		loginInput.focus();
		loginInput.select();
	};

	loginEdit?.addEventListener('click', showLoginEdit);
	loginCancel?.addEventListener('click', showLoginView);

	loginForm?.addEventListener('submit', async (event) => {
		event.preventDefault();
		if (!loginSubmit || !loginError || !loginInput) return;

		loginError.hidden = true;
		const login = loginInput.value.trim();
		if (!login) {
			loginError.textContent = 'El usuario no puede estar vacío';
			loginError.hidden = false;
			return;
		}

		loginSubmit.disabled = true;
		try {
			const response = await fetch('/api/auth/change-login', {
				method: 'POST',
				headers: { 'content-type': 'application/json' },
				body: JSON.stringify({ login }),
			});
			const payload = await response.json();
			if (!response.ok) {
				throw new Error(payload?.error?.message || 'No se pudo actualizar el usuario');
			}
			window.location.assign('/login?loginChanged=1');
		} catch (cause) {
			loginError.textContent =
				cause instanceof Error ? cause.message : 'No se pudo actualizar el usuario';
			loginError.hidden = false;
		} finally {
			loginSubmit.disabled = false;
		}
	});

	const form = document.querySelector<HTMLFormElement>('[data-change-password-form]');
	const error = document.querySelector<HTMLElement>('[data-change-password-error]');
	const submit = form?.querySelector<HTMLButtonElement>('button[type="submit"]');

	form?.addEventListener('submit', async (event) => {
		event.preventDefault();
		if (!submit || !error) return;

		error.hidden = true;
		const data = new FormData(form);
		const currentPassword = String(data.get('currentPassword') || '');
		const newPassword = String(data.get('newPassword') || '');
		const confirmPassword = String(data.get('confirmPassword') || '');

		if (!currentPassword || !newPassword) {
			error.textContent = 'Completá la contraseña actual y la nueva';
			error.hidden = false;
			return;
		}
		if (newPassword !== confirmPassword) {
			error.textContent = 'La confirmación no coincide con la nueva contraseña';
			error.hidden = false;
			return;
		}
		if (currentPassword === newPassword) {
			error.textContent = 'La nueva contraseña debe ser distinta a la actual';
			error.hidden = false;
			return;
		}

		submit.disabled = true;
		try {
			const response = await fetch('/api/auth/change-password', {
				method: 'POST',
				headers: { 'content-type': 'application/json' },
				body: JSON.stringify({ currentPassword, newPassword }),
			});
			const payload = await response.json();
			if (!response.ok) {
				throw new Error(payload?.error?.message || 'No se pudo cambiar la contraseña');
			}
			window.location.assign('/login?changed=1');
		} catch (cause) {
			error.textContent =
				cause instanceof Error ? cause.message : 'No se pudo cambiar la contraseña';
			error.hidden = false;
		} finally {
			submit.disabled = false;
		}
	});
</script>

<style>
	.sg-landing {
		max-width: 42rem;
		margin: 0 auto;
	}
	.sg-landing p {
		margin: 0 0 0.5rem;
		color: var(--sg-text-muted-dark);
		font-size: 0.78rem;
		font-weight: 500;
	}
	.sg-landing h1 {
		margin: 0 0 0.75rem;
		font-size: clamp(2rem, 4vw, 3.2rem);
		font-weight: 600;
		letter-spacing: -0.045em;
		line-height: 1.05;
	}
	.sg-landing-lead {
		font-size: 0.95rem !important;
		font-weight: 400 !important;
		line-height: 1.55;
	}
	.sg-landing-card {
		display: grid;
		gap: 0.65rem;
		margin-top: 1.75rem;
		border-radius: var(--sg-radius-card);
		padding: 1.35rem;
	}
	.sg-landing-card p {
		margin: 0;
		font-size: 0.9rem;
		font-weight: 400;
		line-height: 1.5;
	}
	.sg-settings-account {
		gap: 1.1rem;
	}
	.sg-settings-account-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
	}
	.sg-settings-identity {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		align-items: center;
		gap: 1rem;
		border: 1px solid var(--sg-glass-border);
		border-radius: calc(var(--sg-radius-card) - 0.2rem);
		padding: 0.95rem 1rem;
		background: color-mix(in srgb, var(--sg-glass-fill) 85%, transparent);
	}
	.sg-settings-avatar {
		display: grid;
		place-items: center;
		width: 3rem;
		height: 3rem;
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--sg-flame-yellow) 35%, var(--sg-glass-border));
		color: var(--sg-flame-yellow);
		background: color-mix(in srgb, var(--sg-flame-yellow) 14%, transparent);
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: 0.02em;
	}
	.sg-settings-identity-text {
		display: grid;
		gap: 0.35rem;
		min-width: 0;
	}
	.sg-settings-identity-name {
		margin: 0 !important;
		color: var(--sg-text-on-dark) !important;
		font-size: 1.15rem !important;
		font-weight: 650 !important;
		letter-spacing: -0.02em;
		line-height: 1.2 !important;
		overflow-wrap: anywhere;
	}
	.sg-settings-identity-login {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.45rem 0.65rem;
		margin: 0 !important;
		color: rgba(255, 255, 255, 0.55) !important;
		font-size: 0.78rem !important;
		font-weight: 500 !important;
	}
	.sg-settings-identity-login code {
		border: 1px solid var(--sg-glass-border);
		border-radius: 0.45rem;
		padding: 0.18rem 0.45rem;
		color: var(--sg-text-on-dark);
		background: color-mix(in srgb, var(--sg-glass-fill) 80%, transparent);
		font-family: ui-monospace, 'Cascadia Code', 'Segoe UI Mono', monospace;
		font-size: 0.8rem;
		font-weight: 600;
	}
	.sg-settings-edit-btn,
	.sg-settings-cancel {
		border: 1px solid var(--sg-glass-border);
		border-radius: var(--sg-radius-pill);
		padding: 0.28rem 0.7rem;
		color: var(--sg-text-on-dark);
		background: var(--sg-glass-fill);
		font: inherit;
		font-size: 0.75rem;
		font-weight: 650;
		cursor: pointer;
	}
	.sg-settings-login-form {
		display: grid;
		gap: 0.75rem;
		margin-top: 0.35rem;
	}
	.sg-settings-login-form[hidden] {
		display: none !important;
	}
	.sg-settings-identity-login[hidden] {
		display: none !important;
	}
	.sg-settings-login-form label {
		display: grid;
		gap: 0.4rem;
	}
	.sg-settings-login-form input {
		width: 100%;
		box-sizing: border-box;
		border: 1px solid var(--sg-glass-border);
		border-radius: var(--sg-radius-card);
		padding: 0.7rem 0.85rem;
		color: var(--sg-text-on-dark);
		background: var(--sg-glass-fill);
		font: inherit;
	}
	.sg-settings-login-actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.55rem;
	}
	.sg-settings-login-actions .sg-landing-cta {
		margin-top: 0;
	}
	.sg-settings-form span,
	.sg-settings-login-form span {
		color: rgba(255, 255, 255, 0.58);
		font-size: 0.78rem;
		font-weight: 500;
	}
	.sg-settings-form,
	.sg-settings-form label {
		display: grid;
		gap: 0.45rem;
	}
	.sg-settings-form {
		gap: 1rem;
		margin-top: 0.35rem;
	}
	.sg-settings-form input {
		width: 100%;
		box-sizing: border-box;
		border: 1px solid var(--sg-glass-border);
		border-radius: var(--sg-radius-card);
		padding: 0.75rem 0.85rem;
		color: var(--sg-text-on-dark);
		background: var(--sg-glass-fill);
		font: inherit;
	}
	.sg-settings-error {
		margin: 0 !important;
		color: var(--sg-ember-coral) !important;
	}
	.sg-landing-cta {
		justify-self: start;
		margin-top: 0.35rem;
		border: 1px solid var(--sg-glass-border);
		border-radius: var(--sg-radius-pill);
		padding: 0.65rem 1rem;
		color: var(--sg-text-on-dark);
		background: var(--sg-glass-fill);
		font-size: 0.85rem;
		font-weight: 650;
		text-decoration: none;
	}
	button.sg-landing-cta {
		cursor: pointer;
	}
	button.sg-landing-cta:disabled {
		cursor: wait;
		opacity: 0.65;
	}
	.sg-landing-back {
		margin-top: 1.5rem;
	}
	.sg-landing-back a {
		color: var(--sg-text-muted-dark);
		font-size: 0.85rem;
		text-decoration: none;
	}
</style>
