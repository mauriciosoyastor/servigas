---
import ShellLayout from '../layouts/ShellLayout.astro';
import TileCard from '../components/TileCard.astro';
import ComingSoonNote from '../components/ComingSoonNote.astro';
import { BffError } from '../lib/bff/errors.ts';
import { getBackend } from '../lib/bff/get-backend.ts';
import { invalidateBffSession, requireOdooSession } from '../lib/bff/http.ts';
import type { LauncherTile } from '../lib/bff/types.ts';

let odooSessionId: string;
let userName = '';

try {
	const sessionEntry = requireOdooSession(Astro.cookies);
	odooSessionId = sessionEntry.odooSessionId;
	userName = sessionEntry.session.name || sessionEntry.session.login;
} catch {
	invalidateBffSession(Astro.cookies);
	return Astro.redirect('/login');
}

let tiles: LauncherTile[] = [];
let launcherError = '';

try {
	tiles = (await getBackend().getLauncher(odooSessionId)).tiles;
} catch (cause) {
	if (cause instanceof BffError && cause.code === 'unauthorized') {
		invalidateBffSession(Astro.cookies);
		return Astro.redirect('/login');
	}
	launcherError = 'No pudimos cargar los accesos. Intentá nuevamente en unos minutos.';
}
---

<ShellLayout title="Inicio | Servigas" active="home" userName={userName}>
	<main class="sg-launcher">
		<header class="sg-launcher-heading">
			<div>
				<p>Panel principal</p>
				<h1>¿Qué querés gestionar hoy?</h1>
			</div>
			<span>{tiles.length} {tiles.length === 1 ? 'acceso' : 'accesos'}</span>
		</header>

		<nav class="sg-ops-strip" aria-label="Atajos del mostrador">
			<a class="sg-ops-strip-primary sg-focus-ring" href="/pos">Caja / Mostrador</a>
			<a class="sg-ops-strip-link sg-focus-ring" href="/lists/sales/quotations/new">Nueva cotización</a>
			<a class="sg-ops-strip-link sg-focus-ring" href="/lists/purchase/solicitudes/new">Nuevo pedido a proveedor</a>
		</nav>

		{launcherError ? (
			<section class="sg-launcher-state sg-glass" role="alert">
				<strong>No se pudieron cargar los accesos</strong>
				<p>{launcherError}</p>
			</section>
		) : tiles.length ? (
			<section class="sg-launcher-grid" aria-label="Aplicaciones disponibles">
				{tiles.map((tile) => <TileCard tile={tile} />)}
			</section>
		) : (
			<section class="sg-launcher-state sg-glass">
				<strong>Todavía no hay accesos configurados</strong>
				<p>Cuando el administrador publique aplicaciones, aparecerán en este espacio.</p>
			</section>
		)}
	</main>
	<ComingSoonNote />
</ShellLayout>

<script>
	import { resolveTileNavigation } from '../lib/shell/tile-nav.ts';

	const note = document.querySelector<HTMLElement>('[data-coming-soon]');
	let noteTimer: ReturnType<typeof setTimeout> | undefined;

	document.querySelectorAll<HTMLElement>('[data-tile]').forEach((tile) => {
		tile.addEventListener('click', () => {
			let action: Record<string, unknown> | undefined;
			if (tile.dataset.action) {
				try {
					action = JSON.parse(decodeURIComponent(tile.dataset.action));
				} catch {
					action = undefined;
				}
			}

			const destination = resolveTileNavigation({
				target_type: tile.dataset.targetType || '',
				client_tag: tile.dataset.clientTag || '',
				label: tile.dataset.label,
				action,
			});

			if (
				destination.kind === 'hub' ||
				destination.kind === 'list' ||
				destination.kind === 'route'
			) {
				window.location.href = destination.path;
				return;
			}

			if (note) {
				const detail = note.querySelector('[data-coming-soon-detail]');
				const label = (tile.dataset.label || '').trim();
				if (detail) {
					detail.textContent = label
						? `«${label}» todavía no está disponible.`
						: 'Esta pantalla todavía no está disponible.';
				}
				note.hidden = false;
				window.clearTimeout(noteTimer);
				noteTimer = window.setTimeout(() => {
					note.hidden = true;
				}, 5000);
			}
		});
	});

	document.querySelector('[data-coming-soon-close]')?.addEventListener('click', () => {
		if (note) note.hidden = true;
	});
</script>

<style>
	.sg-launcher {
		max-width: 78rem;
		margin: 0 auto;
	}
	.sg-launcher-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1.25rem;
	}
	.sg-ops-strip {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		margin-bottom: 1.75rem;
	}
	.sg-ops-strip-primary,
	.sg-ops-strip-link {
		display: inline-flex;
		align-items: center;
		border-radius: var(--sg-radius-pill);
		padding: 0.7rem 1.1rem;
		font-size: 0.88rem;
		font-weight: 650;
		text-decoration: none;
	}
	.sg-ops-strip-primary {
		color: #fff;
		background: var(--sg-flame-gradient);
		box-shadow: var(--sg-shadow-flame, 0 12px 28px rgba(230, 74, 25, 0.3));
	}
	.sg-ops-strip-link {
		color: var(--sg-text-on-dark);
		border: 1px solid var(--sg-glass-border);
		background: var(--sg-glass-fill);
	}
	.sg-launcher-heading p {
		margin: 0 0 0.5rem;
		color: var(--sg-text-muted-dark);
		font-size: 0.78rem;
		font-weight: 500;
	}
	.sg-launcher-heading h1 {
		max-width: 48rem;
		margin: 0;
		font-size: clamp(2rem, 4vw, 3.7rem);
		font-weight: 600;
		letter-spacing: -0.045em;
		line-height: 1.05;
	}
	.sg-launcher-heading > span {
		flex: none;
		border: 1px solid var(--sg-glass-border);
		border-radius: var(--sg-radius-pill);
		padding: 0.55rem 0.8rem;
		color: var(--sg-text-muted-dark);
		background: var(--sg-glass-fill);
		font-size: 0.7rem;
		font-weight: 600;
	}
	.sg-launcher-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
		gap: 1rem;
	}
	.sg-launcher-state {
		border-radius: var(--sg-radius-card);
		padding: 2rem;
	}
	.sg-launcher-state strong {
		font-size: 1.1rem;
	}
	.sg-launcher-state p {
		margin: 0.55rem 0 0;
		color: var(--sg-text-muted-dark);
		font-size: 0.88rem;
	}
	@media (max-width: 560px) {
		.sg-launcher-heading {
			align-items: start;
			flex-direction: column;
		}
	}
</style>
