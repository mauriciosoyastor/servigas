---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Servigas — Frontend">
	<main class="mx-auto flex min-h-dvh max-w-5xl flex-col justify-center gap-8 px-6 py-16">
		<div
			class="rounded-sg-card border border-sg-flame-deep/10 bg-[var(--sg-glass-fill)] p-8 shadow-[var(--sg-glass-rim)] backdrop-blur-[var(--sg-glass-blur)]"
		>
			<p class="text-sm font-semibold tracking-wide text-sg-flame-orange uppercase">
				Servigas · Liquid Glass v2
			</p>
			<h1 class="mt-2 text-3xl font-semibold text-sg-text">Frontend Astro listo</h1>
			<p class="mt-3 max-w-xl text-sg-text/70">
				Tailwind v4 con tokens de marca alineados a <code>servigas_tokens.scss</code>.
			</p>
		</div>
	</main>
</BaseLayout>
