---
import ShellLayout from '../layouts/ShellLayout.astro';
import { BffError } from '../lib/bff/errors.ts';
import { getBackend } from '../lib/bff/get-backend.ts';
import { invalidateBffSession, requireOdooSession } from '../lib/bff/http.ts';
import type { PosCatalogPayload } from '../lib/bff/types.ts';

let userName = '';
let catalog: PosCatalogPayload | null = null;
let error = '';
const q = Astro.url.searchParams.get('q') || '';

try {
	const { session, odooSessionId } = requireOdooSession(Astro.cookies);
	userName = session.name || session.login;
	try {
		catalog = await getBackend().getPosCatalog(odooSessionId, { q, limit: 48 });
	} catch (cause) {
		if (cause instanceof BffError && cause.code === 'unauthorized') {
			invalidateBffSession(Astro.cookies);
			return Astro.redirect('/login');
		}
		error = 'No pudimos cargar el catálogo del mostrador.';
	}
} catch {
	invalidateBffSession(Astro.cookies);
	return Astro.redirect('/login');
}
---

<ShellLayout title="Mostrador | Servigas" active="sales" userName={userName}>
	<main class="sg-pos" data-pos-caja>
		<header class="sg-pos-heading">
			<div>
				<p>{catalog?.config?.name || 'Punto de venta'}</p>
				<h1>Caja</h1>
			</div>
			<div class="sg-pos-heading-actions">
				<a class="sg-pos-link sg-focus-ring" href="/lists/sales/pos-orders">Historial POS</a>
				<a class="sg-pos-link sg-focus-ring" href="/">Inicio</a>
			</div>
		</header>

		{error ? (
			<section class="sg-pos-state sg-glass" role="alert">
				<strong>Error</strong>
				<p>{error}</p>
			</section>
		) : (
			<div class="sg-pos-layout">
				<section class="sg-pos-catalog sg-glass" aria-label="Catálogo">
					<form class="sg-pos-search" method="get" action="/pos">
						<label>
							<span class="sr-only">Buscar producto</span>
							<input
								class="sg-focus-ring"
								type="search"
								name="q"
								value={q}
								placeholder="Buscar por nombre o código…"
							/>
						</label>
						<button class="sg-focus-ring" type="submit">Buscar</button>
					</form>
					<p class="sg-pos-meta">{catalog?.total ?? 0} productos</p>
					<div class="sg-pos-scroll sg-pos-catalog-scroll" tabindex="0" aria-label="Lista de productos">
						<div class="sg-pos-grid" data-pos-grid>
							{(catalog?.products || []).map((product) => (
								<button
									class="sg-pos-product sg-focus-ring"
									type="button"
									data-pos-add
									data-id={product.id}
									data-name={product.name}
									data-price={product.list_price}
									data-image={product.image_url || ''}
								>
									{product.image_url ? (
										<img src={product.image_url} alt="" loading="lazy" />
									) : (
										<span class="sg-pos-product-empty" aria-hidden="true">Sin foto</span>
									)}
									<span class="sg-pos-product-name">{product.name}</span>
									<span class="sg-pos-product-code">{product.default_code || '—'}</span>
									<span class="sg-pos-product-price">
										{product.list_price.toLocaleString('es-AR', {
											style: 'currency',
											currency: 'ARS',
											maximumFractionDigits: 0,
										})}
									</span>
								</button>
							))}
						</div>
						{(catalog?.products || []).length === 0 ? (
							<p class="sg-pos-empty">No hay productos para mostrar.</p>
						) : null}
					</div>
				</section>

				<aside class="sg-pos-cart sg-glass" aria-label="Ticket">
					<div class="sg-pos-cart-ticket">
						<strong>Ticket</strong>
						<ul
							class="sg-pos-scroll sg-pos-cart-lines"
							data-pos-lines
							tabindex="0"
							aria-label="Líneas del ticket"
						></ul>
						<p class="sg-pos-cart-empty" data-pos-empty>
							Ticket vacío. Tocá un producto del catálogo para empezar.
						</p>
					</div>
					<div
						class="sg-pos-scroll sg-pos-cart-ops"
						tabindex="0"
						aria-label="Teclado y cobro"
					>
						<section class="sg-pos-numpad" data-pos-numpad aria-label="Teclado">
							<div class="sg-pos-numpad-modes" role="group" aria-label="Modo">
								<button type="button" class="sg-focus-ring" data-np-mode="qty">Qty</button>
								<button type="button" class="sg-focus-ring" data-np-mode="price">Precio</button>
								<button
									type="button"
									class="sg-focus-ring"
									data-np-mode="discount"
									title="Descuento % de la línea seleccionada"
								>
									% línea
								</button>
								<button
									type="button"
									class="sg-focus-ring"
									data-np-mode="order_discount"
									title="Descuento % sobre el total del ticket"
								>
									Desc. total
								</button>
							</div>
							<p class="sg-pos-numpad-hint" data-np-hint>Elegí una línea y un modo</p>
							<p class="sg-pos-numpad-buffer" data-np-buffer aria-live="polite">—</p>
							<p class="sg-pos-numpad-order" data-np-order-disc hidden></p>
							<div class="sg-pos-numpad-keys" data-np-keys>
								{['7', '8', '9', '4', '5', '6', '1', '2', '3', '.', '0', '⌫'].map((key) => (
									<button
										type="button"
										class="sg-focus-ring"
										data-np-key={key === '⌫' ? 'back' : key}
									>
										{key}
									</button>
								))}
							</div>
							<button type="button" class="sg-pos-numpad-apply sg-focus-ring" data-np-apply>
								Aplicar
							</button>
						</section>
						<fieldset class="sg-pos-pay-methods" data-pos-pay-methods>
							<legend>Pago</legend>
							{(catalog?.paymentMethods || []).map((method, index) => (
								<label>
									<input
										type="radio"
										name="pos-pay"
										value={method.id}
										checked={index === 0}
										data-pos-pay-method
									/>
									<span>{method.name}</span>
								</label>
							))}
							{(catalog?.paymentMethods || []).length === 0 ? (
								<p class="sg-pos-empty">Sin métodos de pago configurados.</p>
							) : null}
						</fieldset>
						<div class="sg-pos-cart-totals">
							<div class="sg-pos-cart-subrow" data-pos-order-disc-row hidden>
								<span>Desc. total</span>
								<strong data-pos-order-disc-value>0%</strong>
							</div>
							<div class="sg-pos-cart-total">
								<span>Total</span>
								<strong data-pos-total>$ 0</strong>
							</div>
							<button
								type="button"
								class="sg-pos-total-disc sg-focus-ring"
								data-pos-order-disc
								title="Descuento personalizable sobre el total del ticket"
							>
								Desc. al total…
							</button>
						</div>
						<button class="sg-pos-pay sg-focus-ring" type="button" data-pos-checkout disabled>
							Registrar venta
						</button>
						<p class="sg-pos-cart-status" data-pos-status hidden></p>
						<section class="sg-pos-receipt" data-pos-receipt hidden>
							<strong>Venta registrada</strong>
							<p data-pos-receipt-name></p>
							<p data-pos-receipt-meta></p>
							<p class="sg-pos-receipt-total" data-pos-receipt-total></p>
							<div class="sg-pos-receipt-actions">
								<button type="button" class="sg-focus-ring" data-pos-receipt-new>
									Nueva venta
								</button>
								<a class="sg-focus-ring" data-pos-receipt-detail href="#">Ver pedido</a>
							</div>
						</section>
					</div>
				</aside>
			</div>
		)}
	</main>
</ShellLayout>

<script>
	import {
		addToCart,
		cartTotal,
		checkoutLinesFromCart,
		emptyCart,
		lineSubtotal,
		removeFromCart,
		setCartDiscount,
		setCartPrice,
		setCartQty,
		setOrderDiscount,
	} from '../lib/pos/cart.ts';
	import {
		bufferValue,
		emptyNumpad,
		pressBackspace,
		pressDigit,
		selectLine,
		setNumpadMode,
	} from '../lib/pos/numpad.ts';

	const root = document.querySelector('[data-pos-caja]');
	if (root) {
		let cart = emptyCart();
		let pad = emptyNumpad();
		const linesEl = root.querySelector('[data-pos-lines]');
		const emptyEl = root.querySelector('[data-pos-empty]');
		const totalEl = root.querySelector('[data-pos-total]');
		const checkoutBtn = root.querySelector('[data-pos-checkout]');
		const statusEl = root.querySelector('[data-pos-status]');
		const receiptEl = root.querySelector('[data-pos-receipt]');
		const receiptNameEl = root.querySelector('[data-pos-receipt-name]');
		const receiptMetaEl = root.querySelector('[data-pos-receipt-meta]');
		const receiptTotalEl = root.querySelector('[data-pos-receipt-total]');
		const receiptDetailEl = root.querySelector('[data-pos-receipt-detail]');
		const receiptNewBtn = root.querySelector('[data-pos-receipt-new]');
		const bufferEl = root.querySelector('[data-np-buffer]');
		const orderDiscEl = root.querySelector('[data-np-order-disc]');
		const hintEl = root.querySelector('[data-np-hint]');
		const orderDiscRow = root.querySelector('[data-pos-order-disc-row]');
		const orderDiscValueEl = root.querySelector('[data-pos-order-disc-value]');

		const money = (value) =>
			value.toLocaleString('es-AR', {
				style: 'currency',
				currency: 'ARS',
				maximumFractionDigits: 0,
			});

		const selectedPaymentMethodId = () => {
			const checked = root.querySelector('[data-pos-pay-method]:checked');
			return checked ? Number(checked.value) : undefined;
		};

		const hideReceipt = () => {
			if (receiptEl) receiptEl.hidden = true;
		};

		const showReceipt = (payload) => {
			if (
				!(
					receiptEl &&
					receiptNameEl &&
					receiptMetaEl &&
					receiptTotalEl &&
					receiptDetailEl
				)
			) {
				return;
			}
			receiptNameEl.textContent = payload.orderName || 'Venta';
			const pay =
				payload.paymentMethodName ||
				(payload.channel === 'pos.order' ? 'POS' : 'Pedido');
			receiptMetaEl.textContent = `Pago: ${pay}`;
			receiptTotalEl.textContent = money(Number(payload.amountTotal) || 0);
			receiptDetailEl.href = payload.detailPath || '/lists/sales/pos-orders';
			receiptEl.hidden = false;
		};

		const beginDiscount = (mode, productId = null) => {
			if (productId != null) {
				pad = selectLine(pad, productId);
			}
			pad = setNumpadMode(pad, mode);
			render();
		};

		const syncNumpadChrome = () => {
			if (bufferEl) {
				bufferEl.textContent = pad.buffer || '—';
			}
			root.querySelectorAll('[data-np-mode]').forEach((btn) => {
				const mode = btn.getAttribute('data-np-mode');
				btn.setAttribute('aria-pressed', mode === pad.mode ? 'true' : 'false');
				btn.classList.toggle('is-active', mode === pad.mode);
			});
			const orderPct = Number(cart.orderDiscount) || 0;
			if (orderDiscEl) {
				orderDiscEl.hidden = orderPct <= 0;
				orderDiscEl.textContent =
					orderPct > 0 ? `Desc. total activo: ${orderPct}%` : '';
			}
			if (orderDiscRow && orderDiscValueEl) {
				orderDiscRow.hidden = orderPct <= 0;
				orderDiscValueEl.textContent = `−${orderPct}%`;
			}
			if (hintEl) {
				if (pad.mode === 'qty') {
					hintEl.textContent = pad.selectedProductId
						? 'Cantidad: escribí y Aplicar'
						: 'Seleccioná una línea del ticket';
				} else if (pad.mode === 'price') {
					hintEl.textContent = pad.selectedProductId
						? 'Precio unitario: escribí y Aplicar'
						: 'Seleccioná una línea del ticket';
				} else if (pad.mode === 'discount') {
					hintEl.textContent = pad.selectedProductId
						? 'Desc. % de la línea: escribí (0–100) y Aplicar'
						: 'Tocá % en una línea o seleccioná producto';
				} else if (pad.mode === 'order_discount') {
					hintEl.textContent =
						'Desc. % del total del ticket: escribí (0–100) y Aplicar';
				}
			}
		};

		const applyNumpad = () => {
			const value = bufferValue(pad);
			if (value == null) return;
			if (pad.mode === 'order_discount') {
				cart = setOrderDiscount(cart, value);
				pad = { ...pad, buffer: '' };
				render();
				return;
			}
			if (pad.selectedProductId == null) return;
			const id = pad.selectedProductId;
			if (pad.mode === 'qty') {
				cart = setCartQty(cart, id, value);
			} else if (pad.mode === 'price') {
				cart = setCartPrice(cart, id, value);
			} else if (pad.mode === 'discount') {
				cart = setCartDiscount(cart, id, value);
			}
			pad = { ...pad, buffer: '' };
			if (!cart.lines.some((line) => line.productId === id)) {
				pad = selectLine(pad, cart.lines[0]?.productId ?? null);
			}
			render();
		};

		const render = () => {
			if (!(linesEl && emptyEl && totalEl && checkoutBtn)) return;
			if (
				pad.selectedProductId != null &&
				!cart.lines.some((line) => line.productId === pad.selectedProductId)
			) {
				pad = selectLine(pad, cart.lines[0]?.productId ?? null);
			}
			linesEl.innerHTML = '';
			for (const line of cart.lines) {
				const li = document.createElement('li');
				const selected = pad.selectedProductId === line.productId;
				li.classList.toggle('is-selected', selected);
				li.setAttribute('data-line-id', String(line.productId));
				li.innerHTML = `
					<button type="button" class="sg-pos-line-select sg-focus-ring" data-select>
						<span class="sg-pos-line-thumb" data-line-thumb aria-hidden="true"></span>
						<span class="sg-pos-line-copy">
							<strong></strong>
							<span data-line-total></span>
							<small></small>
						</span>
					</button>
					<div class="sg-pos-line-actions">
						<button type="button" class="sg-pos-line-disc" data-line-disc aria-label="Descuento de línea">
							%
						</button>
						<div class="sg-pos-qty">
							<button type="button" data-dec aria-label="Menos">−</button>
							<em></em>
							<button type="button" data-inc aria-label="Más">+</button>
							<button type="button" data-rm aria-label="Quitar">×</button>
						</div>
					</div>
				`;
				li.querySelector('strong').textContent = line.name;
				li.querySelector('[data-line-total]').textContent = money(lineSubtotal(line));
				const meta = [];
				meta.push(`${line.qty} × ${money(line.price)}`);
				if (line.discount) meta.push(`−${line.discount}%`);
				li.querySelector('small').textContent = meta.join(' · ');
				li.querySelector('em').textContent = String(line.qty);
				const discBtn = li.querySelector('[data-line-disc]');
				if (line.discount) {
					discBtn.textContent = `−${Math.round(line.discount)}%`;
					discBtn.classList.add('has-disc');
				}
				const thumb = li.querySelector('[data-line-thumb]');
				if (line.imageUrl) {
					const img = document.createElement('img');
					img.src = line.imageUrl;
					img.alt = '';
					img.loading = 'lazy';
					thumb.appendChild(img);
				} else {
					thumb.classList.add('is-empty');
				}
				li.querySelector('[data-select]').addEventListener('click', () => {
					pad = selectLine(pad, line.productId);
					render();
				});
				discBtn.addEventListener('click', () => {
					beginDiscount('discount', line.productId);
				});
				li.querySelector('[data-dec]').addEventListener('click', () => {
					cart = setCartQty(cart, line.productId, line.qty - 1);
					render();
				});
				li.querySelector('[data-inc]').addEventListener('click', () => {
					cart = setCartQty(cart, line.productId, line.qty + 1);
					render();
				});
				li.querySelector('[data-rm]').addEventListener('click', () => {
					cart = removeFromCart(cart, line.productId);
					render();
				});
				linesEl.appendChild(li);
			}
			emptyEl.hidden = cart.lines.length > 0;
			totalEl.textContent = money(cartTotal(cart));
			checkoutBtn.disabled = cart.lines.length === 0;
			syncNumpadChrome();
		};

		root.querySelectorAll('[data-pos-add]').forEach((button) => {
			button.addEventListener('click', () => {
				const productId = Number(button.getAttribute('data-id'));
				const imageUrl = button.getAttribute('data-image') || '';
				cart = addToCart(cart, {
					productId,
					name: button.getAttribute('data-name') || 'Producto',
					price: Number(button.getAttribute('data-price') || 0),
					qty: 1,
					imageUrl: imageUrl || undefined,
				});
				pad = selectLine(pad, productId);
				render();
			});
		});

		root.querySelectorAll('[data-np-mode]').forEach((btn) => {
			btn.addEventListener('click', () => {
				const mode = btn.getAttribute('data-np-mode');
				if (
					mode === 'qty' ||
					mode === 'price' ||
					mode === 'discount' ||
					mode === 'order_discount'
				) {
					pad = setNumpadMode(pad, mode);
					syncNumpadChrome();
				}
			});
		});

		root.querySelector('[data-pos-order-disc]')?.addEventListener('click', () => {
			beginDiscount('order_discount');
		});

		root.querySelectorAll('[data-np-key]').forEach((btn) => {
			btn.addEventListener('click', () => {
				const key = btn.getAttribute('data-np-key');
				if (key === 'back') {
					pad = pressBackspace(pad);
				} else if (key) {
					pad = pressDigit(pad, key);
				}
				syncNumpadChrome();
			});
		});

		root.querySelector('[data-np-apply]')?.addEventListener('click', () => {
			applyNumpad();
		});

		checkoutBtn?.addEventListener('click', async () => {
			if (!statusEl || !checkoutBtn) return;
			hideReceipt();
			checkoutBtn.disabled = true;
			statusEl.hidden = false;
			statusEl.textContent = 'Registrando venta…';
			statusEl.dataset.state = 'pending';
			try {
				const response = await fetch('/api/pos/checkout', {
					method: 'POST',
					credentials: 'same-origin',
					headers: { 'content-type': 'application/json' },
					body: JSON.stringify({
						paymentMethodId: selectedPaymentMethodId(),
						lines: checkoutLinesFromCart(cart),
					}),
				});
				const payload = await response.json().catch(() => ({}));
				if (!response.ok) {
					throw new Error(payload?.error?.message || 'No se pudo registrar');
				}
				statusEl.textContent = 'Listo';
				statusEl.dataset.state = 'ok';
				cart = emptyCart();
				pad = emptyNumpad();
				render();
				showReceipt(payload);
			} catch (error) {
				statusEl.textContent =
					error instanceof Error ? error.message : 'No se pudo registrar';
				statusEl.dataset.state = 'error';
				checkoutBtn.disabled = cart.lines.length === 0;
			}
		});

		receiptNewBtn?.addEventListener('click', () => {
			hideReceipt();
			if (statusEl) {
				statusEl.hidden = true;
				statusEl.textContent = '';
			}
			cart = emptyCart();
			pad = emptyNumpad();
			render();
		});

		render();
	}
</script>

<style>
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		border: 0;
	}
	.sg-pos {
		max-width: 92rem;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		min-height: 0;
		height: calc(100dvh - 10.5rem);
	}
	.sg-pos-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
		flex: 0 0 auto;
		flex-wrap: wrap;
	}
	.sg-pos-heading p {
		margin: 0 0 0.4rem;
		color: var(--sg-text-muted-dark);
		font-size: 0.78rem;
		font-weight: 500;
	}
	.sg-pos-heading h1 {
		margin: 0;
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 600;
		letter-spacing: -0.045em;
	}
	.sg-pos-heading-actions {
		display: flex;
		gap: 0.6rem;
	}
	.sg-pos-link {
		border: 1px solid var(--sg-glass-border);
		border-radius: var(--sg-radius-pill);
		padding: 0.55rem 0.9rem;
		color: var(--sg-text-on-dark);
		background: var(--sg-glass-fill);
		font-size: 0.8rem;
		font-weight: 600;
		text-decoration: none;
	}
	.sg-pos-layout {
		display: grid;
		grid-template-columns: minmax(0, 1.6fr) minmax(0, 0.9fr);
		gap: 1rem;
		align-items: stretch;
		flex: 1 1 auto;
		min-height: 0;
	}
	.sg-pos-scroll {
		overflow-x: hidden;
		overflow-y: auto;
		overscroll-behavior: contain;
		scrollbar-width: none;
		-ms-overflow-style: none;
		min-height: 0;
	}
	.sg-pos-scroll::-webkit-scrollbar {
		width: 0;
		height: 0;
		display: none;
	}
	.sg-pos-catalog,
	.sg-pos-cart {
		border-radius: var(--sg-radius-card);
		padding: 1rem;
		min-width: 0;
		min-height: 0;
		max-height: 100%;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		overflow: hidden;
	}
	.sg-pos-catalog-scroll {
		flex: 1 1 auto;
	}
	.sg-pos-search {
		display: flex;
		gap: 0.5rem;
		margin-bottom: 0;
		flex: 0 0 auto;
	}
	.sg-pos-search label {
		flex: 1;
	}
	.sg-pos-search input {
		width: 100%;
		border: 1px solid var(--sg-glass-border);
