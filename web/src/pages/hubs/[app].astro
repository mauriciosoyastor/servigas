---
import ShellLayout from '../../layouts/ShellLayout.astro';
import TileCard from '../../components/TileCard.astro';
import ComingSoonNote from '../../components/ComingSoonNote.astro';
import { BffError } from '../../lib/bff/errors.ts';
import { getBackend } from '../../lib/bff/get-backend.ts';
import { invalidateBffSession, requireOdooSession } from '../../lib/bff/http.ts';
import type { HubCard } from '../../lib/bff/types.ts';
import { isHubApp, type HubApp } from '../../lib/shell/hub-apps.ts';

const app = Astro.params.app ?? '';
const validApp = isHubApp(app);
let userName = '';
let cards: HubCard[] = [];
let hubError = '';

const HUB_LABELS: Record<HubApp, string> = {
	inventory: 'Inventario',
	sales: 'Ventas',
	purchase: 'Compras',
	accounting: 'Contabilidad',
};

if (!validApp) {
	Astro.response.status = 404;
} else {
	let odooSessionId: string;

	try {
		const { session, odooSessionId: sessionId } = requireOdooSession(Astro.cookies);
		odooSessionId = sessionId;
		userName = session.name || session.login;
	} catch {
		invalidateBffSession(Astro.cookies);
		return Astro.redirect('/login');
	}

	try {
		const payload = await getBackend().getHub(odooSessionId, app, 'summary');
		cards = payload.cards;
	} catch (cause) {
		if (cause instanceof BffError && cause.code === 'unauthorized') {
			invalidateBffSession(Astro.cookies);
			return Astro.redirect('/login');
		}
		hubError = 'No pudimos cargar este hub. Intentá nuevamente en unos minutos.';
	}
}
---

{validApp ? (
	<ShellLayout title={`${HUB_LABELS[app]} | Servigas`} active={app} userName={userName}>
		<main class="sg-hub">
			<header class="sg-hub-heading">
				<div>
					<p>Resumen operativo</p>
					<h1>{HUB_LABELS[app]}</h1>
				</div>
				<span>{cards.length} {cards.length === 1 ? 'acceso' : 'accesos'}</span>
			</header>

			{hubError ? (
				<section class="sg-hub-state sg-glass" role="alert">
					<strong>No se pudo abrir el hub</strong>
					<p>{hubError}</p>
				</section>
			) : cards.length ? (
				<section class="sg-hub-grid" aria-label={`Accesos de ${HUB_LABELS[app]}`}>
					{cards.map((card) => (
						<TileCard tile={{ ...card, target_type: 'action', client_tag: '' }} />
					))}
				</section>
			) : (
				<section class="sg-hub-state sg-glass">
					<strong>Sin tarjetas en este resumen</strong>
					<p>No hay accesos configurados para mostrar en este hub.</p>
				</section>
			)}
		</main>
		<ComingSoonNote />
	</ShellLayout>
) : (
	<h1>Hub no encontrado</h1>
)}

<script>
	const note = document.querySelector<HTMLElement>('[data-coming-soon]');
	let noteTimer: ReturnType<typeof setTimeout> | undefined;

	document.querySelectorAll<HTMLElement>('[data-tile]').forEach((tile) => {
		tile.addEventListener('click', () => {
			if (!note) return;
			note.hidden = false;
			window.clearTimeout(noteTimer);
			noteTimer = window.setTimeout(() => {
				note.hidden = true;
			}, 5000);
		});
	});

	document.querySelector('[data-coming-soon-close]')?.addEventListener('click', () => {
		if (note) note.hidden = true;
	});
</script>

<style>
	.sg-hub {
		max-width: 78rem;
		margin: 0 auto;
	}
	.sg-hub-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 2rem;
	}
	.sg-hub-heading p {
		margin: 0 0 0.5rem;
		color: var(--sg-text-muted-dark);
		font-size: 0.78rem;
		font-weight: 500;
	}
	.sg-hub-heading h1 {
		margin: 0;
		font-size: clamp(2rem, 4vw, 3.7rem);
		font-weight: 600;
		letter-spacing: -0.045em;
		line-height: 1.05;
	}
	.sg-hub-heading > span {
		flex: none;
		border: 1px solid var(--sg-glass-border);
		border-radius: var(--sg-radius-pill);
		padding: 0.55rem 0.8rem;
		color: var(--sg-text-muted-dark);
		background: var(--sg-glass-fill);
		font-size: 0.7rem;
		font-weight: 600;
	}
	.sg-hub-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
		gap: 1rem;
	}
	.sg-hub-state {
		border-radius: var(--sg-radius-card);
		padding: 2rem;
	}
	.sg-hub-state strong {
		font-size: 1.1rem;
	}
	.sg-hub-state p {
		margin: 0.55rem 0 0;
		color: var(--sg-text-muted-dark);
		font-size: 0.88rem;
	}
	@media (max-width: 560px) {
		.sg-hub-heading {
			align-items: start;
			flex-direction: column;
		}
	}
</style>
