---
import OrderCreateForm from '../../../../components/OrderCreateForm.astro';
import ShellLayout from '../../../../layouts/ShellLayout.astro';
import { invalidateBffSession, requireOdooSession } from '../../../../lib/bff/http.ts';

let userName = '';

try {
	const { session } = requireOdooSession(Astro.cookies);
	userName = session.name || session.login;
} catch {
	invalidateBffSession(Astro.cookies);
	return Astro.redirect('/login');
}
---

<ShellLayout title="Nueva factura | Servigas" active="accounting" userName={userName}>
	<main class="sg-create-page">
		<header>
			<p>Contabilidad</p>
			<h1>Nueva factura de cliente</h1>
		</header>
		<OrderCreateForm
			apiPath="/api/records/accounting/customer-invoices"
			listPath="/lists/accounting/customer-invoices"
			partnerListKey="sales/customers"
			productListKey="inventory/variants"
			title="Alta de factura"
			hint="Elegí cliente (se muestra destino CF/CUIT) y líneas. Queda en borrador; publicá desde la ficha."
			partnerLabel="Cliente"
			partnerPlaceholder="Buscar cliente…"
			submitLabel="Crear borrador"
		/>
	</main>
</ShellLayout>

<style>
	.sg-create-page {
		max-width: 40rem;
		margin: 0 auto;
		display: grid;
		gap: 1.25rem;
	}
	.sg-create-page header p {
		margin: 0 0 0.35rem;
		color: var(--sg-text-muted-dark);
		font-size: 0.78rem;
		font-weight: 500;
	}
	.sg-create-page header h1 {
		margin: 0;
		font-size: clamp(1.8rem, 3.5vw, 2.4rem);
		font-weight: 600;
		letter-spacing: -0.04em;
	}
</style>
