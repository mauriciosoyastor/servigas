---
import RecordDetailBody from '../../../../components/RecordDetailBody.astro';
import RecordInvoicePdfControl from '../../../../components/RecordInvoicePdfControl.astro';
import ShellLayout from '../../../../layouts/ShellLayout.astro';
import { loadRecordDetail } from '../../../../lib/shell/load-record-detail.ts';

const id = Number(Astro.params.id);
const loaded = await loadRecordDetail(
	Astro.cookies,
	'accounting/vendor-refunds',
	id,
	'No encontramos esta nota de crédito de proveedor.'
);
if (loaded.kind === 'redirect') {
	return Astro.redirect(loaded.path);
}
if (loaded.status) Astro.response.status = loaded.status;
const { userName, detail, error } = loaded;
---

<ShellLayout title={`${detail?.title || 'NC proveedor'} | Servigas`} active="accounting" userName={userName}>
	<RecordDetailBody
		detail={detail}
		error={error}
		eyebrow="Ficha de NC proveedor"
		fallbackTitle="NC proveedor"
		fallbackListPath="/lists/accounting/vendor-refunds"
		recordId={id}
	>
		{detail && !error ? (
			<RecordInvoicePdfControl
				slot="secondary"
				listKey="accounting/vendor-refunds"
				recordId={id}
				title={detail.title}
			/>
		) : null}
	</RecordDetailBody>
</ShellLayout>
