---
import RecordConfirmControl from '../../../../components/RecordConfirmControl.astro';
import RecordDetailBody from '../../../../components/RecordDetailBody.astro';
import RecordInvoicePdfControl from '../../../../components/RecordInvoicePdfControl.astro';
import RecordRegisterPaymentControl from '../../../../components/RecordRegisterPaymentControl.astro';
import ShellLayout from '../../../../layouts/ShellLayout.astro';
import { loadRecordDetail } from '../../../../lib/shell/load-record-detail.ts';
import { isPaymentRegisterableState } from '../../../../lib/shell/payment-registers.ts';
import { isConfirmableState } from '../../../../lib/shell/record-actions.ts';

const id = Number(Astro.params.id);
const loaded = await loadRecordDetail(
	Astro.cookies,
	'accounting/vendor-bills',
	id,
	'No encontramos esta factura de proveedor.'
);
if (loaded.kind === 'redirect') {
	return Astro.redirect(loaded.path);
}
if (loaded.status) Astro.response.status = loaded.status;
const { userName, detail, error } = loaded;

function fieldValue(key: string): string {
	const hit = detail?.fields.find((field) => field.key === key);
	if (hit?.value === null || hit?.value === undefined) return '';
	return String(hit.value);
}

const state = fieldValue('state');
const paymentState = fieldValue('payment_state');
const residual = fieldValue('amount_residual');
const showPublish = isConfirmableState('accounting/vendor-bills', state);
const showPay = isPaymentRegisterableState(state, paymentState);
---

<ShellLayout title={`${detail?.title || 'Factura proveedor'} | Servigas`} active="accounting" userName={userName}>
	<RecordDetailBody
		detail={detail}
		error={error}
		eyebrow="Ficha de factura de proveedor"
		fallbackTitle="Factura proveedor"
		fallbackListPath="/lists/accounting/vendor-bills"
		recordId={id}
	>
		{detail && !error ? (
			<RecordInvoicePdfControl
				slot="secondary"
				listKey="accounting/vendor-bills"
				recordId={id}
				title={detail.title}
			/>
		) : null}
		{detail && !error && showPublish ? (
			<RecordConfirmControl
				slot="secondary"
				listKey="accounting/vendor-bills"
				recordId={id}
				apiPath="/api/records/accounting/vendor-bills"
				label="Publicar"
				confirmMessage="¿Publicar esta factura de proveedor?"
				pendingLabel="Publicando…"
				okLabel="Publicada"
			/>
		) : null}
		{detail && !error && showPay ? (
			<RecordRegisterPaymentControl
				slot="secondary"
				listKey="accounting/vendor-bills"
				recordId={id}
				apiPath="/api/records/accounting/vendor-bills"
				defaultAmount={residual}
				label="Registrar pago"
				directionLabel="pago a proveedor"
			/>
		) : null}
	</RecordDetailBody>
</ShellLayout>
