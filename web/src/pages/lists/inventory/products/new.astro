---
import RecordCreateForm from '../../../../components/RecordCreateForm.astro';
import ShellLayout from '../../../../layouts/ShellLayout.astro';
import { invalidateBffSession, requireOdooSession } from '../../../../lib/bff/http.ts';

let userName = '';
try {
	const { session } = requireOdooSession(Astro.cookies);
	userName = session.name || session.login;
} catch {
	invalidateBffSession(Astro.cookies);
	return Astro.redirect('/login');
}
---

<ShellLayout title="Nuevo producto | Servigas" active="inventory" userName={userName}>
	<main class="sg-create-page">
		<header>
			<p>Inventario</p>
			<h1>Nuevo producto</h1>
		</header>
		<RecordCreateForm
			listKey="inventory/products"
			apiPath="/api/records/inventory/products"
			listPath="/lists/inventory/products"
			title="Alta de producto"
			hint="Plantilla vendible, almacenable y disponible en caja. Campos mínimos allowlisted."
			fields={[
				{ key: 'name', label: 'Nombre', required: true },
				{ key: 'default_code', label: 'Referencia interna' },
				{ key: 'list_price', label: 'Precio de venta' },
			]}
		/>
	</main>
</ShellLayout>

<style>
	.sg-create-page {
		max-width: 40rem;
		margin: 0 auto;
		display: grid;
		gap: 1.25rem;
	}
	.sg-create-page header p {
		margin: 0 0 0.35rem;
		color: var(--sg-text-muted-dark);
		font-size: 0.78rem;
		font-weight: 500;
	}
	.sg-create-page header h1 {
		margin: 0;
		font-size: clamp(1.8rem, 3.5vw, 2.4rem);
		font-weight: 600;
		letter-spacing: -0.04em;
	}
</style>
