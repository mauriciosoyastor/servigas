---
import RecordConfirmControl from '../../../../components/RecordConfirmControl.astro';
import RecordDetailBody from '../../../../components/RecordDetailBody.astro';
import ShellLayout from '../../../../layouts/ShellLayout.astro';
import { loadRecordDetail } from '../../../../lib/shell/load-record-detail.ts';
import { isConfirmableState } from '../../../../lib/shell/record-actions.ts';

const id = Number(Astro.params.id);
const loaded = await loadRecordDetail(
	Astro.cookies,
	'inventory/transfers',
	id,
	'No encontramos esta transferencia.'
);
if (loaded.kind === 'redirect') {
	return Astro.redirect(loaded.path);
}
if (loaded.status) Astro.response.status = loaded.status;
const { userName, detail, error } = loaded;

function fieldValue(key: string): string {
	const hit = detail?.fields.find((field) => field.key === key);
	if (hit?.value === null || hit?.value === undefined) return '';
	return String(hit.value);
}

const state = fieldValue('state');
const showValidate = isConfirmableState('inventory/transfers', state);
---

<ShellLayout title={`${detail?.title || 'Transferencia'} | Servigas`} active="inventory" userName={userName}>
	<RecordDetailBody
		detail={detail}
		error={error}
		eyebrow="Ficha de transferencia"
		fallbackTitle="Transferencia"
		fallbackListPath="/lists/inventory/transfers"
	/>
	{detail && !error && showValidate ? (
		<RecordConfirmControl
			listKey="inventory/transfers"
			recordId={id}
			apiPath="/api/records/inventory/transfers"
			label="Validar recepción"
		/>
	) : null}
</ShellLayout>
