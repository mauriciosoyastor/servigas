---
import OrderCreateForm from '../../../../components/OrderCreateForm.astro';
import ShellLayout from '../../../../layouts/ShellLayout.astro';
import { invalidateBffSession, requireOdooSession } from '../../../../lib/bff/http.ts';

let userName = '';

try {
	const { session } = requireOdooSession(Astro.cookies);
	userName = session.name || session.login;
} catch {
	invalidateBffSession(Astro.cookies);
	return Astro.redirect('/login');
}
---

<ShellLayout title="Nuevo pedido a proveedor | Servigas" active="purchase" userName={userName}>
	<main class="sg-create-page">
		<header>
			<p>Compras</p>
			<h1>Nuevo pedido a proveedor</h1>
		</header>
		<OrderCreateForm
			apiPath="/api/records/purchase/solicitudes"
			listPath="/lists/purchase/solicitudes"
			partnerListKey="purchase/vendors"
			productListKey="inventory/variants"
			title="Pedido a proveedor"
			hint="Buscá proveedor y agregá líneas (cant., precio, % desc.). Queda en borrador para confirmar."
			partnerLabel="Proveedor"
			partnerPlaceholder="Buscar proveedor…"
		/>
	</main>
</ShellLayout>

<style>
	.sg-create-page {
		max-width: 40rem;
		margin: 0 auto;
		display: grid;
		gap: 1.25rem;
	}
	.sg-create-page header p {
		margin: 0 0 0.35rem;
		color: var(--sg-text-muted-dark);
		font-size: 0.78rem;
		font-weight: 500;
	}
	.sg-create-page header h1 {
		margin: 0;
		font-size: clamp(1.8rem, 3.5vw, 2.4rem);
		font-weight: 600;
		letter-spacing: -0.04em;
	}
</style>
