---
import RecordConfirmControl from '../../../../components/RecordConfirmControl.astro';
import RecordDetailBody from '../../../../components/RecordDetailBody.astro';
import RecordNotes from '../../../../components/RecordNotes.astro';
import ShellLayout from '../../../../layouts/ShellLayout.astro';
import { loadRecordDetail } from '../../../../lib/shell/load-record-detail.ts';
import { isConfirmableState } from '../../../../lib/shell/record-actions.ts';

const id = Number(Astro.params.id);
const loaded = await loadRecordDetail(
	Astro.cookies,
	'purchase/orders',
	id,
	'No encontramos esta orden de compra.'
);
if (loaded.kind === 'redirect') {
	return Astro.redirect(loaded.path);
}
if (loaded.status) Astro.response.status = loaded.status;
const { userName, detail, error } = loaded;

function fieldValue(key: string): string {
	const hit = detail?.fields.find((field) => field.key === key);
	if (hit?.value === null || hit?.value === undefined) return '';
	return String(hit.value);
}

const state = fieldValue('state');
// Confirm uses purchase/solicitudes allowlist even when opened from orders detail path
const showConfirm = isConfirmableState('purchase/solicitudes', state);
---

<ShellLayout title={`${detail?.title || 'Orden de compra'} | Servigas`} active="purchase" userName={userName}>
	<RecordDetailBody
		detail={detail}
		error={error}
		eyebrow="Ficha de compra"
		fallbackTitle="Orden de compra"
		fallbackListPath="/lists/purchase/orders"
	/>
	{detail && !error && showConfirm ? (
		<RecordConfirmControl
			listKey="purchase/solicitudes"
			recordId={id}
			apiPath="/api/records/purchase/solicitudes"
			label="Confirmar OC"
		/>
	) : null}
	{detail && !error ? (
		<RecordNotes listKey="purchase/orders" recordId={id} />
	) : null}
</ShellLayout>
